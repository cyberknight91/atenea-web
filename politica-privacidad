  <style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
      --granate: #7a0019;
      --granate-dark: #5c0012;
    }

    * { box-sizing: border-box; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #0a0a0f;
      color: #e8e6e0;
      overflow-x: hidden;
    }

    h1, h2, h3, .brand { font-family: 'Syne', sans-serif; }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.4;
    }

    /* ---- NAVBAR ---- */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 10, 15, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(122, 0, 25, 0.2);
    }

    .brand {
      font-size: 1.2rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #fff;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .brand span { color: var(--granate); }

    nav a {
      font-size: 0.875rem;
      font-weight: 400;
      color: rgba(232, 230, 224, 0.65);
      transition: color 0.2s;
      text-decoration: none;
    }

    nav a:hover { color: #fff; }

    .nav-cta {
      background: var(--granate);
      color: #fff !important;
      padding: 0.45rem 1.1rem;
      border-radius: 4px;
      font-weight: 500 !important;
      transition: background 0.2s !important;
    }

    .nav-cta:hover { background: var(--granate-dark) !important; }

    #menu-toggle { display: none; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
    .hamburger span { display: block; width: 22px; height: 2px; background: #e8e6e0; border-radius: 2px; transition: all 0.25s; }

    @media (max-width: 768px) {
      .hamburger { display: flex; }
      .nav-links { display: none; flex-direction: column; gap: 0; width: 100%; border-top: 1px solid rgba(255,255,255,0.07); padding: 0.75rem 0 0.5rem; }
      .nav-links a { padding: 0.6rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.95rem; }
      .nav-links a:last-child { border-bottom: none; }
      #menu-toggle:checked ~ .nav-links { display: flex; }
      #menu-toggle:checked ~ label .hamburger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      #menu-toggle:checked ~ label .hamburger span:nth-child(2) { opacity: 0; }
      #menu-toggle:checked ~ label .hamburger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    }

    /* ---- CONTENIDO LEGAL ---- */
    .legal-section {
      padding-top: 5rem;
      padding-bottom: 5rem;
      position: relative;
      z-index: 10;
    }

    .legal-header {
      border-bottom: 1px solid rgba(255,255,255,0.07);
      padding-bottom: 2.5rem;
      margin-bottom: 3rem;
    }

    .page-label {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--granate);
      margin-bottom: 0.75rem;
    }

    .legal-block {
      padding-bottom: 2.5rem;
      margin-bottom: 2.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .legal-block:last-child { border-bottom: none; margin-bottom: 0; }

    .legal-block h2 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .legal-block h2::before {
      content: '';
      width: 3px;
      height: 18px;
      background: var(--granate);
      border-radius: 2px;
      flex-shrink: 0;
    }

    .legal-block p {
      font-size: 0.9rem;
      color: rgba(232,230,224,0.5);
      line-height: 1.85;
      font-weight: 300;
      margin-bottom: 0.75rem;
    }

    .legal-block p:last-child { margin-bottom: 0; }

    .legal-block ul {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .legal-block ul li {
      font-size: 0.9rem;
      color: rgba(232,230,224,0.5);
      line-height: 1.7;
      font-weight: 300;
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }

    .legal-block ul li::before {
      content: '';
      width: 4px;
      height: 4px;
      min-width: 4px;
      background: var(--granate);
      border-radius: 50%;
      margin-top: 8px;
    }

    .info-box {
      background: rgba(122,0,25,0.06);
      border: 1px solid rgba(122,0,25,0.2);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 0.75rem;
    }

    .info-box p { color: rgba(232,230,224,0.55) !important; margin-bottom: 0 !important; }
    .info-box strong { color: rgba(232,230,224,0.8); font-weight: 500; }

    /* Tabla de derechos */
    .rights-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .right-item {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 8px;
      padding: 1rem 1.1rem;
      transition: border-color 0.2s;
    }

    .right-item:hover { border-color: rgba(122,0,25,0.3); }

    .right-item strong {
      display: block;
      font-size: 0.83rem;
      font-weight: 600;
      color: rgba(232,230,224,0.8);
      margin-bottom: 0.3rem;
    }

    .right-item span {
      font-size: 0.78rem;
      color: rgba(232,230,224,0.35);
      font-weight: 300;
      line-height: 1.5;
    }

    /* TOC */
    .toc {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 1.5rem;
      position: sticky;
      top: 80px;
    }

    .toc-title {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(232,230,224,0.3);
      margin-bottom: 1rem;
    }

    .toc a {
      display: block;
      font-size: 0.82rem;
      color: rgba(232,230,224,0.4);
      text-decoration: none;
      padding: 0.35rem 0;
      border-left: 2px solid transparent;
      padding-left: 0.75rem;
      transition: all 0.2s;
      font-weight: 300;
    }

    .toc a:hover { color: #fff; border-left-color: var(--granate); }

    /* Footer */
    footer { background: #060608; border-top: 1px solid rgba(255,255,255,0.06); }
    footer a { color: rgba(232,230,224,0.3); transition: color 0.2s; text-decoration: none; }
    footer a:hover { color: #fff; }

    .cc-btn { margin-left: 8px; border-radius: 6px; font-weight: 500; }
